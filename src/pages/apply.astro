---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import Headline from "@/components/ui/Headline.astro";
import ApplicationForm from "@/components/forms/ApplicationForm.astro";
import WidgetWrapper from "@/components/widgets/WidgetWrapper.astro";
import { Icon } from "astro-icon/components";
import { programConfig } from "@/config/program";
import { siteConfig } from "@/config/site";

const metadata = {
  title: `Apply | ${siteConfig.name}`,
  description:
    "Apply to Ship It Island. Share your project, what's stuck, what you want to ship, and which June or July 2026 cohort works for you.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <WidgetWrapper containerClass="pt-8 md:pt-14">
    <div
      class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.85fr)] lg:items-start"
    >
      <div class="space-y-8">
        <Headline
          classes={{
            container: "max-w-4xl",
            subtitle: "max-w-2xl text-lg",
            title: "text-5xl font-extrabold tracking-tight md:text-6xl",
          }}
          subtitle="Tell us about your project, what's stuck, what you want to ship, and which cohort works for you."
          tagline="Application"
          title="Apply to Ship It Island"
          titleAs="h1"
        />
        <div class="flex flex-col gap-4 sm:flex-row">
          <Button href="/#pricing" variant="secondary"> Review pricing </Button>
          <Button href="/#faq" variant="secondary"> Read the FAQ </Button>
        </div>
      </div>
      <Card class="space-y-5">
        <h2 class="text-2xl font-bold tracking-tight text-foreground">
          What happens after you submit
        </h2>
        <div class="grid gap-4">
          <div
            class="flex items-start gap-3 rounded-2xl border border-border bg-background px-4 py-3"
          >
            <Icon
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              name="lucide:inbox"
            />
            <p class="text-sm text-muted-foreground">
              Your submission is added to the waitlist review queue.
            </p>
          </div>
          <div
            class="flex items-start gap-3 rounded-2xl border border-border bg-background px-4 py-3"
          >
            <Icon
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              name="lucide:check-check"
            />
            <p class="text-sm text-muted-foreground">
              A confirmation page shows that you're on the waitlist and what
              happens next.
            </p>
          </div>
          <div
            class="flex items-start gap-3 rounded-2xl border border-border bg-background px-4 py-3"
          >
            <Icon
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              name="lucide:messages-square"
            />
            <p class="text-sm text-muted-foreground">
              Applications are reviewed manually on a rolling basis. If there's
              a fit, you'll hear from us directly by email or Telegram.
            </p>
          </div>
        </div>
        <div
          class="rounded-2xl border border-primary/20 bg-primary/10 p-4 text-sm text-muted-foreground"
        >
          {programConfig.cohort.applySummary}
        </div>
        <div class="rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-sm font-semibold text-foreground">Direct contact</p>
          <p class="mt-2 text-sm text-muted-foreground">
            Telegram:
            <a
              href={`https://t.me/${siteConfig.contact.telegram.replace(/^@/, "")}`}
              target="_blank"
              rel="noreferrer"
              class="transition-colors hover:text-primary"
            >
              {siteConfig.contact.telegram}
            </a>
          </p>
          <p class="text-sm text-muted-foreground">
            <a
              href={`mailto:${siteConfig.contact.email}`}
              class="transition-colors hover:text-primary"
            >
              {siteConfig.contact.email}
            </a>
          </p>
        </div>
      </Card>
    </div>
  </WidgetWrapper>

  <WidgetWrapper containerClass="pt-0">
    <ApplicationForm />
  </WidgetWrapper>
</BaseLayout>
