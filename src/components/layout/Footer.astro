---
import { siteConfig } from "@/config/site";
import { programConfig } from "@/config/program";
---

<footer class="mt-20 border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div
      class="grid gap-8 md:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)_auto] md:items-start"
    >
      <div class="space-y-3">
        <span class="text-lg font-bold text-foreground">{siteConfig.name}</span>
        <p class="max-w-xl text-sm text-muted-foreground">
          {siteConfig.description}
        </p>
        <p class="text-sm text-muted-foreground">
          {programConfig.cohort.location} · {programConfig.cohort.timeframe}
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <span
          class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
        >
          Explore
        </span>
        {
          siteConfig.navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted-foreground transition-colors hover:text-primary"
            >
              {link.text}
            </a>
          ))
        }
      </div>
      <div class="rounded-3xl border border-border bg-background p-5">
        <p class="text-sm font-semibold text-foreground">Applications open</p>
        <p class="mt-2 text-sm text-muted-foreground">
          Small, curated cohort. Manual review and outreach follow each
          submission.
        </p>
        <div class="mt-4 space-y-1 text-sm text-muted-foreground">
          <p>Telegram: {siteConfig.contact.telegram}</p>
          <p>{siteConfig.contact.email}</p>
        </div>
        <a
          href={programConfig.ctas.apply.href}
          class="mt-4 inline-flex rounded-full bg-foreground px-4 py-2 text-sm font-semibold text-background transition hover:bg-foreground/90"
        >
          {programConfig.ctas.apply.label}
        </a>
      </div>
    </div>
    <div
      class="mt-8 border-t border-border pt-8 text-center text-xs text-muted-foreground"
    >
      &copy; {new Date().getFullYear()}
      {siteConfig.author}. All rights reserved.
    </div>
  </div>
</footer>
